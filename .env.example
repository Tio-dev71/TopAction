# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: DO NOT expose this in client code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Payment: VNPay ----
PAYMENT_PROVIDER=sepay
VNPAY_TMN_CODE=your-merchant-code
VNPAY_HASH_SECRET=your-hash-secret
# Test: https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Production: https://pay.vnpay.vn/vpcpay.html
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html


# ---- Manual Banking Information (VietQR) ----
NEXT_PUBLIC_BANK_ID=MB
NEXT_PUBLIC_BANK_ACCOUNT_NO=0977831621
NEXT_PUBLIC_BANK_ACCOUNT_NAME=NGUYEN DINH THO

# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---- Strava Tracking ----
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_WEBHOOK_VERIFY_TOKEN=your-random-strong-string

# ---- Garmin Connect (OAuth 1.0a) ----
# Register at https://developerprogram.garmin.com/ (Enterprise only)
GARMIN_CONSUMER_KEY=your-garmin-consumer-key
GARMIN_CONSUMER_SECRET=your-garmin-consumer-secret
